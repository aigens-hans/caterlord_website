---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { languages } from '@/i18n/config';
import { alternatesFor } from '@/i18n/utils';

interface Props {
  lang: import('@/i18n/config').Lang;
  title: string;
  description?: string;
  seo?: {
    title?: string;
    description?: string;
    image?: string;
    noindex?: boolean;
  };
}

const { lang, title, seo = {} } = Astro.props;

const metaTitle = seo.title ?? title;
const metaDescription = seo.description ?? '';
const path = Astro.url.pathname;
const alternates = alternatesFor(path);
const canonical = new URL(path, Astro.site).toString();
const ogImage = seo.image ? new URL(seo.image, Astro.site).toString() : undefined;
---

<!doctype html>
<html lang={lang} dir={languages[lang].dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{metaTitle}</title>
    {metaDescription && <meta name="description" content={metaDescription} />}
    <link rel="canonical" href={canonical} />
    {seo.noindex && <meta name="robots" content="noindex, nofollow" />}

    {/* hreflang alternates for multilingual SEO */}
    {alternates.map((alt) => <link rel="alternate" hreflang={alt.hreflang} href={new URL(alt.href, Astro.site).toString()} />)}
    <link rel="alternate" hreflang="x-default" href={new URL(alternates.find((a) => a.lang === 'en')?.href ?? '/', Astro.site).toString()} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={metaTitle} />
    {metaDescription && <meta property="og:description" content={metaDescription} />}
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Fonts — “Grid” system: Anton (display) · Space Grotesk (body) · JetBrains Mono (labels) */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
