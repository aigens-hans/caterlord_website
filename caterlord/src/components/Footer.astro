---
import { localizePath, t } from '@/i18n/utils';
import type { Lang } from '@/i18n/config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const year = new Date().getFullYear();

const cols = [
  {
    title: t(lang, 'nav.products'),
    links: [
      { href: '/caterlord-pos/', label: 'Caterlord POS' },
      { href: '/caterlord-mobile/', label: 'Caterlord Mobile' },
    ],
  },
  {
    title: t(lang, 'nav.solutions'),
    links: [
      { href: '/solutions/', label: t(lang, 'nav.solutions') },
      { href: '/success-stories/', label: t(lang, 'nav.successStories') },
    ],
  },
  {
    title: t(lang, 'footer.about'),
    links: [
      { href: '/about/', label: t(lang, 'footer.about') },
      { href: '/contact/', label: t(lang, 'footer.contact') },
      { href: '/partners/', label: t(lang, 'footer.partners') },
    ],
  },
];
---

<footer class="site-footer bw-t">
  <div class="container grid">
    <div class="brand-col">
      <img src="/uploads/2024/11/logo_Caterlord_b-1.png" alt="Caterlord" />
      <p class="mono contact">{t(lang, 'nav.bookDemo')} · +852 6888-0133</p>
    </div>
    {cols.map((col) => (
      <div>
        <h4 class="mono">{col.title}</h4>
        <ul>
          {col.links.map((l) => (
            <li><a href={localizePath(l.href, lang)}>{l.label}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>
  <div class="container bottom mono">
    <span>© {year} Caterlord · Everyware</span>
    <span>caterlord.com</span>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--ink);
    color: #d8d8d8;
    margin-top: 0;
  }
  .grid {
    display: grid;
    grid-template-columns: 1.6fr repeat(3, 1fr);
    gap: 28px;
    padding-block: 44px 32px;
  }
  .brand-col img {
    height: 26px;
    filter: brightness(0) invert(1);
    margin-bottom: 12px;
  }
  .contact {
    color: #9a9a9a;
    text-transform: none;
    letter-spacing: 0.04em;
  }
  h4 {
    font-family: var(--mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #7d7d7d;
    margin: 0 0 12px;
    font-weight: 500;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  li {
    margin-bottom: 6px;
  }
  li a {
    color: #e8e8e8;
    font-size: 0.92rem;
  }
  li a:hover {
    color: var(--blue);
  }
  .bottom {
    border-top: 1px solid #2a2a2a;
    padding-block: 18px;
    color: #7d7d7d;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: flex;
    justify-content: space-between;
    gap: 14px;
    flex-wrap: wrap;
  }
  @media (max-width: 760px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
