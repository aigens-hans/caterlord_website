---
import { localizePath, t } from '@/i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import type { Lang } from '@/i18n/config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const nav = [
  { key: 'nav.products' as const, href: '/products/' },
  { key: 'nav.solutions' as const, href: '/solutions/' },
  { key: 'nav.successStories' as const, href: '/success-stories/' },
  { key: 'nav.blog' as const, href: '/blog/' },
];

const productLinks = [
  { href: '/caterlord-pos/', label: 'Caterlord POS' },
  { href: '/caterlord-mobile/', label: 'Caterlord Mobile' },
];
---

<header class="site-header bw-b">
  <div class="container bar">
    <a class="brand" href={localizePath('/', lang)}>
      <img src="/uploads/2024/11/logo_Caterlord_b-1.png" alt="Caterlord" />
    </a>

    <nav class="nav" aria-label="Primary">
      <details class="dropdown">
        <summary>{t(lang, 'nav.products')}</summary>
        <div class="menu bw sh">
          {productLinks.map((p) => <a href={localizePath(p.href, lang)}>{p.label}</a>)}
        </div>
      </details>
      {nav.slice(1).map((item) => (
        <a href={localizePath(item.href, lang)}>{t(lang, item.key)}</a>
      ))}
    </nav>

    <div class="actions">
      <LanguageSwitcher lang={lang} />
      <a class="btn btn--blue" href={localizePath('/book-a-demo/', lang)}>{t(lang, 'nav.bookDemo')}</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--paper);
  }
  .bar {
    display: flex;
    align-items: center;
    gap: 24px;
    height: 68px;
  }
  .brand img {
    height: 26px;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-left: 6px;
    flex: 1;
  }
  .nav a,
  .nav summary {
    font-weight: 600;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--ink);
    cursor: pointer;
    list-style: none;
  }
  .nav a:hover {
    color: var(--blue-deep);
  }
  .dropdown {
    position: relative;
  }
  .menu {
    position: absolute;
    top: calc(100% + 10px);
    left: 0;
    background: #fff;
    padding: 6px;
    min-width: 210px;
    display: flex;
    flex-direction: column;
  }
  .menu a {
    padding: 9px 12px;
    font-weight: 600;
    font-size: 0.86rem;
  }
  .menu a:hover {
    background: var(--paper-2);
  }
  .actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  @media (max-width: 760px) {
    .nav {
      display: none;
    }
  }
</style>
