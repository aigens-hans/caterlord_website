---
interface Props {
  heading?: string;
  items: { q: string; a: string }[];
}
const { heading, items } = Astro.props;
---

<section class="section section--soft">
  <div class="container">
    {heading && (
      <div class="section__head">
        <h2 class="display">{heading}</h2>
      </div>
    )}
    <div class="faqs bw">
      {items.map((item) => (
        <details class="faq">
          <summary>
            <span>{item.q}</span>
            <span class="plus" aria-hidden="true">+</span>
          </summary>
          <div class="a">{item.a}</div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faqs {
    max-width: 860px;
  }
  .faq {
    border-bottom: var(--bw) solid var(--ink);
    background: #fff;
  }
  .faq:last-child {
    border-bottom: 0;
  }
  .faq summary {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 18px 22px;
    cursor: pointer;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: 0.96rem;
    list-style: none;
  }
  .faq summary::-webkit-details-marker {
    display: none;
  }
  .faq summary span:first-child {
    flex: 1;
  }
  .plus {
    font-family: var(--display);
    font-size: 1.4rem;
    color: var(--blue-deep);
    transition: transform 0.15s ease;
  }
  .faq[open] .plus {
    transform: rotate(45deg);
  }
  .a {
    padding: 0 22px 20px;
    color: var(--soft);
    max-width: 70ch;
  }
</style>
