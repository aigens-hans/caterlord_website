---
interface Props {
  heading?: string;
  images: string[];
}
const { heading, images } = Astro.props;
---

<section class="section section--soft bw-b bw-t">
  <div class="container">
    {heading && (
      <div class="section__head">
        <h2 class="display">{heading}</h2>
      </div>
    )}
    <div class="wall">
      {images.map((src) => (
        <span class="item"><img src={src} alt="" loading="lazy" /></span>
      ))}
    </div>
  </div>
</section>

<style>
  .wall {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.4rem 2rem;
  }
  .item img {
    height: 38px;
    width: auto;
    filter: grayscale(1);
    opacity: 0.7;
    transition: filter 0.2s ease, opacity 0.2s ease;
  }
  .item:hover img {
    filter: none;
    opacity: 1;
  }
</style>
