---
import { getCollection } from 'astro:content';
import { hrefForEntry } from '@/lib/content';
import type { Lang } from '@/i18n/config';

interface Props {
  heading?: string;
  items?: string[];
  lang: Lang;
}
const { heading, items, lang } = Astro.props;

let products = await getCollection('products', (p) => p.data.lang === lang);
if (items && items.length) {
  products = products.filter((p) => items.includes(p.data.translationKey));
}
products.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

{products.length > 0 && (
  <section class="section">
    <div class="container">
      {heading && (
        <div class="section__head">
          <h2 class="display">{heading}</h2>
        </div>
      )}
      <div class="grid bw">
        {products.map((p) => (
          <a class="card" href={hrefForEntry(p)}>
            {p.data.image && (
              <span class="ph">
                <img src={p.data.image} alt="" loading="lazy" />
              </span>
            )}
            <span class="b">
              <h3>{p.data.name}</h3>
              {p.data.tagline && <span class="d">{p.data.tagline}</span>}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }
  .card {
    display: flex;
    flex-direction: column;
    border-right: var(--bw) solid var(--ink);
    border-bottom: var(--bw) solid var(--ink);
    background: #fff;
    color: var(--ink);
    transition: transform 0.08s ease, box-shadow 0.12s ease;
  }
  .card:nth-child(3n) {
    border-right: 0;
  }
  .card:hover {
    transform: translate(-3px, -3px);
    box-shadow: 8px 8px 0 var(--blue-deep);
  }
  .ph {
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-bottom: var(--bw) solid var(--ink);
    background: var(--paper-2);
  }
  .ph img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.15) contrast(1.04);
  }
  .b {
    padding: 14px 16px 18px;
  }
  .card h3 {
    font-family: var(--sans);
    font-weight: 700;
    font-size: 0.96rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin: 0 0 3px;
  }
  .d {
    font-size: 0.85rem;
    color: var(--soft);
  }
  @media (max-width: 860px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }
    .card:nth-child(3n) {
      border-right: var(--bw) solid var(--ink);
    }
    .card:nth-child(2n) {
      border-right: 0;
    }
  }
  @media (max-width: 560px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .card,
    .card:nth-child(3n),
    .card:nth-child(2n) {
      border-right: 0;
    }
  }
</style>
