---
interface Badge {
  image: string;
  href: string;
}
interface Stat {
  value: string;
  label: string;
}
interface Props {
  heading: string;
  headingAccent?: string;
  eyebrow?: string;
  subheading?: string;
  background?: string;
  image?: string;
  cta?: { label: string; href: string };
  badges?: Badge[];
  tags?: string[];
  stats?: Stat[];
}
const {
  heading,
  headingAccent,
  eyebrow,
  subheading,
  background,
  image,
  cta,
  badges = [],
  tags = [],
  stats = [],
} = Astro.props;

const hasStats = stats.length > 0;
const hasBadges = badges.length > 0;
---

<section class="hero">
  <div class="container">
    {tags.length > 0 && (
      <div class="tags">
        {tags.map((t, i) => (
          <span class={`tag ${i === 0 ? 'tag--blue' : ''}`}>{t}</span>
        ))}
      </div>
    )}

    <h1 class="display">
      {heading}{headingAccent && <span class="accent"> {headingAccent}</span>}
    </h1>

    <div class={`grid ${hasStats ? 'grid--stats' : ''}`}>
      <div class="lead">
        {eyebrow && <p class="mono eyebrow">{eyebrow}</p>}
        {subheading && <p class="sub">{subheading}</p>}
        {cta && (
          <div class="ctas">
            <a class="btn btn--blue" href={cta.href}>{cta.label} →</a>
            <a class="btn btn--ghost" href="/products/">See products</a>
          </div>
        )}
        {hasBadges && (
          <div class="badges">
            {badges.map((b) => (
              <a href={b.href}><img src={b.image} alt="" loading="lazy" /></a>
            ))}
          </div>
        )}
      </div>

      {hasStats && (
        <div class="stats bw">
          {stats.map((s) => (
            <div>
              <b class="display">{s.value}</b>
              <span class="mono">{s.label}</span>
            </div>
          ))}
        </div>
      )}

      {!hasStats && image && (
        <div class="hero-img bw sh">
          <img src={image} alt="" />
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    padding: clamp(32px, 6vw, 60px) 0 4px;
    border-bottom: var(--bw) solid var(--ink);
    background: var(--paper);
  }
  .tags {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  h1.display {
    font-size: clamp(3rem, 12vw, 9.5rem);
    margin: 0 0 22px;
  }
  h1.display .accent {
    color: var(--blue-deep);
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 26px;
    margin-top: 6px;
  }
  .grid--stats {
    grid-template-columns: 1.25fr 1fr;
    border: var(--bw) solid var(--ink);
  }
  .grid--stats > .lead {
    padding: clamp(20px, 3vw, 28px);
    border-right: var(--bw) solid var(--ink);
  }
  .eyebrow {
    margin: 0 0 6px;
    color: var(--blue-deep);
  }
  .sub {
    font-size: 1.06rem;
    margin: 0 0 18px;
    max-width: 44ch;
  }
  .ctas {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .stats {
    display: grid;
    grid-template-columns: 1fr;
  }
  .stats > div {
    padding: 18px clamp(18px, 2.5vw, 26px);
  }
  .stats > div + div {
    border-top: var(--bw) solid var(--ink);
  }
  .stats b {
    font-size: clamp(2.6rem, 5vw, 3.6rem);
    display: block;
    line-height: 1;
  }
  .stats span {
    display: block;
    margin-top: 6px;
    color: var(--soft);
  }
  .hero-img {
    overflow: hidden;
  }
  .hero-img img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }
  .badges {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 22px;
  }
  .badges a {
    width: 58px;
    height: 58px;
    border: var(--bw) solid var(--ink);
    background: #fff;
    padding: 11px;
    box-shadow: 4px 4px 0 var(--ink);
    transition: transform 0.1s ease;
  }
  .badges a:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--ink);
  }
  .badges img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  @media (max-width: 820px) {
    .grid--stats {
      grid-template-columns: 1fr;
    }
    .grid--stats > .lead {
      border-right: 0;
      border-bottom: var(--bw) solid var(--ink);
    }
    .stats {
      grid-template-columns: repeat(3, 1fr);
    }
    .stats > div + div {
      border-top: 0;
      border-left: var(--bw) solid var(--ink);
    }
  }
  @media (max-width: 520px) {
    .stats {
      grid-template-columns: 1fr;
    }
    .stats > div + div {
      border-left: 0;
      border-top: var(--bw) solid var(--ink);
    }
  }
</style>
