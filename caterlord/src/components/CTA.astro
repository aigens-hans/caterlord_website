---
interface Props {
  heading: string;
  subheading?: string;
  cta: { label: string; href: string };
}
const { heading, subheading, cta } = Astro.props;
---

<section class="cta">
  <div class="container">
    <h2 class="display">
      {heading}
    </h2>
    {subheading && <p>{subheading}</p>}
    <a class="btn btn--blue" href={cta.href}>{cta.label} →</a>
  </div>
</section>

<style>
  .cta {
    background: var(--ink);
    color: #fff;
    padding: clamp(48px, 8vw, 92px) 0;
    border-top: var(--bw) solid var(--ink);
    text-align: center;
  }
  .cta h2 {
    font-size: clamp(2.2rem, 7vw, 5rem);
    margin: 0 0 22px;
    color: #fff;
  }
  .cta p {
    color: #c9c9c9;
    max-width: 50ch;
    margin: 0 auto 26px;
  }
</style>
