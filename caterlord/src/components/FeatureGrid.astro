---
interface Props {
  heading?: string;
  items: { icon?: string; heading: string; body: string }[];
  columns?: number;
}
const { heading, items, columns = 4 } = Astro.props;
---

<section class="section">
  <div class="container">
    {heading && (
      <div class="section__head">
        <h2 class="display">{heading}</h2>
      </div>
    )}
    <div class="grid bw" style={`--cols:${columns}`}>
      {items.map((item, i) => (
        <article class={`cell ${i === 1 && items.length <= 4 ? 'cell--hot' : ''}`}>
          <span class="num">{String(i + 1).padStart(2, '0')}</span>
          {item.icon && <span class="ic">{item.icon}</span>}
          <h3>{item.heading}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 4), 1fr);
  }
  .cell {
    padding: 24px;
    border-right: var(--bw) solid var(--ink);
    border-bottom: var(--bw) solid var(--ink);
    background: #fff;
    min-height: 210px;
  }
  .cell:last-child {
    border-right: 0;
  }
  .num {
    font-family: var(--display);
    font-size: 1.5rem;
    color: var(--blue-deep);
    line-height: 1;
  }
  .ic {
    display: inline-block;
    margin: 10px 0;
    font-size: 1.4rem;
  }
  .cell h3 {
    font-family: var(--sans);
    font-weight: 700;
    font-size: 1.02rem;
    margin: 0 0 6px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
  .cell p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--soft);
  }
  .cell--hot {
    background: var(--ink);
    color: #fff;
  }
  .cell--hot .num {
    color: var(--accent);
  }
  .cell--hot p {
    color: #bdbdbd;
  }
  @media (max-width: 900px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .cell:nth-child(2n) {
      border-right: 0;
    }
    .cell:last-child {
      border-right: 0;
    }
  }
  @media (max-width: 560px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .cell {
      border-right: 0 !important;
    }
  }
</style>
