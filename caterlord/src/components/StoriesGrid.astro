---
import { getCollection } from 'astro:content';
import { hrefForEntry } from '@/lib/content';
import type { Lang } from '@/i18n/config';

interface Props {
  heading?: string;
  items?: string[];
  lang: Lang;
}
const { heading, items, lang } = Astro.props;

let stories = await getCollection('successStories', (s) => s.data.lang === lang);
if (items && items.length) {
  stories = stories.filter((s) => items.includes(s.data.translationKey));
}
stories = [...stories]
  .sort((a, b) => +new Date(b.data.date ?? 0) - +new Date(a.data.date ?? 0))
  .slice(0, 6);
---

{stories.length > 0 && (
  <section class="section">
    <div class="container">
      {heading && (
        <div class="section__head">
          <h2 class="display">{heading}</h2>
        </div>
      )}
      <div class="grid bw">
        {stories.map((s) => (
          <a class="card" href={hrefForEntry(s, 'success-stories')}>
            {s.data.cover && (
              <span class="ph">
                <img src={s.data.cover} alt="" loading="lazy" />
              </span>
            )}
            <span class="b">
              <h3>{s.data.title}</h3>
              <span class="client">{s.data.client}</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }
  .card {
    display: flex;
    flex-direction: column;
    border-right: var(--bw) solid var(--ink);
    border-bottom: var(--bw) solid var(--ink);
    background: #fff;
    color: var(--ink);
    transition: transform 0.08s ease, box-shadow 0.12s ease;
  }
  .card:nth-child(3n) {
    border-right: 0;
  }
  .card:hover {
    transform: translate(-3px, -3px);
    box-shadow: 8px 8px 0 var(--ink);
  }
  .ph {
    display: block;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-bottom: var(--bw) solid var(--ink);
  }
  .ph img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.15) contrast(1.04);
  }
  .b {
    padding: 14px 16px 18px;
  }
  .card h3 {
    font-family: var(--sans);
    font-weight: 700;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin: 0 0 4px;
  }
  .client {
    font-family: var(--mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--blue-deep);
  }
  @media (max-width: 860px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .card,
    .card:nth-child(3n) {
      border-right: 0;
    }
  }
</style>
